{
  "case_reopened": false,
  "classification": "train_cv_component_selector_does_not_rescue_family_holdouts",
  "decision": {
    "promotion": "rejected_for_generation_method",
    "result": "Train-only component selection chooses the active components for every public-bookcase family. It therefore leaves the same family failures in place. The only selector that rescues them is the heldout oracle, which is posthoc and not a generation rule.",
    "row0_origin_changed": false
  },
  "method": {
    "oracle_selector": "Per-component heldout oracle included only as a ceiling. It sees the target family outcome and is therefore not promotable.",
    "train_cv_selector": "For each outer public-bookcase family holdout, use only the other public-bookcase families inside the training set. A component is kept adaptive only if its internal leave-family-out gain versus uniform is positive."
  },
